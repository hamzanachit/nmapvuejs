{
  "name": "nmapvuejs",
  "version": "1.0.2",
  "description": "Beautiful map components for Vue.js. Built on MapLibre GL, styled with Tailwind CSS.",
  "private": false,
  "type": "module",
  "main": "dist/nmapvuejs.cjs.js",
  "module": "dist/nmapvuejs.es.js",
  "style": "dist/nmapvuejs.css",
  "exports": {
    ".": {
      "import": "./dist/nmapvuejs.es.js",
      "require": "./dist/nmapvuejs.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "preview": "vite preview"
  },
  "keywords": [
    "vue",
    "vue3",
    "map",
    "maplibre",
    "maplibre-gl",
    "maps",
    "components",
    "vue-components"
  ],
  "author": "hamzanachit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamzanachit/nmapvuejs.git"
  },
  "bugs": {
    "url": "https://github.com/hamzanachit/nmapvuejs/issues"
  },
  "homepage": "https://github.com/hamzanachit/nmapvuejs",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "maplibre-gl": "^3.0.0 || ^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "postcss": "^8.5.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  }
}